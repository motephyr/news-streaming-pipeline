# ─────────────────────────────────────────────────────────────────────────────
# .env.example — 複製此檔案為 .env，填入真實的值
# 注意：.env 已加入 .gitignore，請勿將 API key 提交至版本控制
# ─────────────────────────────────────────────────────────────────────────────

# NewsAPI 金鑰（申請：https://newsapi.org/register）
NEWSAPI_KEY=your_newsapi_key_here

# Kafka 設定
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
NEWS_TOPIC=raw-news
FETCH_INTERVAL_SECONDS=300   # Producer 每隔幾秒抓一次新聞（free tier 建議 300+）

# PostgreSQL 設定
# 預設配合 docker-compose.full.yml（內建 postgres 服務）
# 若改用 docker-compose.yml（外部 DB），請將 POSTGRES_HOST 改為 host.docker.internal
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=newsdb
POSTGRES_USER=newsuser
POSTGRES_PASSWORD=your_postgres_password

# Airflow 管理員帳號（首次初始化使用）
AIRFLOW_ADMIN_USERNAME=admin
AIRFLOW_ADMIN_PASSWORD=admin
AIRFLOW_ADMIN_EMAIL=admin@example.com
